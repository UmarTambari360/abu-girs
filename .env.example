# .env.example
# Copy this file to .env.local and fill in all values before running locally.

# PostgreSQL connection string (with PostGIS enabled)
# Local Docker example: postgresql://girs:girs@localhost:5432/girs
# Railway example: copied from the Railway PostgreSQL service Variables tab
DATABASE_URL=

# NextAuth secret — generate with: openssl rand -hex 32
AUTH_SECRET=

# Seeded admin credentials — used by scripts/seed.ts to create the first admin user
ADMIN_EMAIL=
ADMIN_PASSWORD=

# Node environment
NODE_ENV=development