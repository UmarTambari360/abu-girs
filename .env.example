# PostgreSQL connection string (PostGIS-enabled)
DATABASE_URL=postgresql://girs_user:girs_password@localhost:5434/girs_db

# NextAuth secret — generate with: openssl rand -hex 32
AUTH_SECRET=your_auth_secret_at_least_32_chars_long

# Admin credentials used by the seed script and credentials provider
ADMIN_EMAIL=admin@girs.abu.edu.ng
ADMIN_PASSWORD=admin123

# Node environment
NODE_ENV=development